<view class="chronicle-page">
  <app-nav title="见证" variant="glass" />

  <!-- 顶区：一级胶囊；报备时显示次级 Tab 壳 -->
  <view class="chronicle-header">
    <view class="chronicle-header-surface">
      <view class="chronicle-header-inner">
        <view class="chronicle-mode-split" aria-label="内容类型切换">
          <view
            class="chronicle-mode-thumb {{mainModule === 'report' ? 'chronicle-mode-thumb--right' : ''}}"
            aria-hidden="true"
          />
          <view class="chronicle-mode-cells">
            <view
              class="chronicle-mode-cell {{mainModule === 'daily' ? 'chronicle-mode-cell--on' : ''}}"
              data-mode="daily"
              bind:tap="onMainTab"
              aria-role="tab"
              aria-selected="{{mainModule === 'daily'}}"
            >
              <text class="chronicle-mode-name">日常</text>
            </view>
            <view
              class="chronicle-mode-cell {{mainModule === 'report' ? 'chronicle-mode-cell--on' : ''}}"
              data-mode="report"
              bind:tap="onMainTab"
              aria-role="tab"
              aria-selected="{{mainModule === 'report'}}"
            >
              <text class="chronicle-mode-name">报备</text>
            </view>
          </view>
        </view>

        <view wx:if="{{mainModule === 'report'}}" class="chronicle-toolbar">
          <view class="chronicle-toolbar-shell">
            <view class="chronicle-report-tabs" aria-label="报备范围">
              <view class="chronicle-report-rail">
                <view
                  class="chronicle-report-thumb chronicle-report-thumb--{{reportFilterIndex}}"
                  aria-hidden="true"
                />
                <view class="chronicle-report-tabs-row">
                  <view
                    class="chronicle-report-tab {{reportFilter === 'pending' ? 'chronicle-report-tab--active' : ''}}"
                    data-filter="pending"
                    bind:tap="onReportFilter"
                    aria-role="tab"
                    aria-selected="{{reportFilter === 'pending'}}"
                  >
                    <text class="chronicle-report-tab-label">待阅读</text>
                  </view>
                  <view
                    class="chronicle-report-tab {{reportFilter === 'all' ? 'chronicle-report-tab--active' : ''}}"
                    data-filter="all"
                    bind:tap="onReportFilter"
                    aria-role="tab"
                    aria-selected="{{reportFilter === 'all'}}"
                  >
                    <text class="chronicle-report-tab-label">全部</text>
                  </view>
                  <view
                    class="chronicle-report-tab {{reportFilter === 'mine' ? 'chronicle-report-tab--active' : ''}}"
                    data-filter="mine"
                    bind:tap="onReportFilter"
                    aria-role="tab"
                    aria-selected="{{reportFilter === 'mine'}}"
                  >
                    <text class="chronicle-report-tab-label">我的</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <swiper
    class="chronicle-swiper"
    current="{{swiperCurrent}}"
    bindchange="onSwiperChange"
    duration="{{280}}"
    cache-extent="1"
    indicator-dots="{{false}}"
  >
    <swiper-item class="chronicle-swiper-item">
      <scroll-view
        class="chronicle-pane-scroll"
        scroll-y
        type="list"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
        bounces="{{true}}"
        enable-passive="{{true}}"
        cache-extent="320"
        refresher-enabled="{{true}}"
        refresher-triggered="{{dailyRefreshing}}"
        bindrefresherrefresh="onDailyRefresh"
        bindscrolltolower="onDailyScrollToLower"
        lower-threshold="{{120}}"
      >
        <view class="chronicle-scroll-body chronicle-daily-feed">
          <view
            wx:for="{{dailyList}}"
            wx:key="id"
            list-item
            class="daily-post daily-post--no-foot"
            data-id="{{item.id}}"
            bind:longpress="onDailyPostLongPress"
          >
            <view class="daily-post__body">
              <view class="daily-post__main">
                <view class="daily-post__head">
                  <view class="daily-post__avatar-shell">
                    <image
                      wx:if="{{ item.avatarUrl }}"
                      class="daily-post__avatar daily-post__avatar--photo"
                      src="{{ item.avatarUrl }}"
                      mode="aspectFill"
                    />
                    <view
                      wx:else
                      class="daily-post__avatar-ph daily-post__ph--{{ item.avatarTone || 'dew' }}"
                      aria-hidden="true"
                    >
                      <view class="daily-post__ph-shine" />
                    </view>
                  </view>
                  <view class="daily-post__head-main">
                    <view class="daily-post__head-row">
                      <view class="daily-post__name">{{item.userName}}</view>
                      <text class="daily-post__time">{{item.time}}</text>
                    </view>
                  </view>
                </view>
                <view
                  wx:if="{{ item.snippet || item.images.length }}"
                  class="daily-post__content"
                >
                  <view wx:if="{{item.snippet}}" class="daily-post__prose">
                    <text class="daily-post__text">{{item.snippet}}</text>
                  </view>
                  <view wx:if="{{ item.images.length }}" class="daily-post__media">
                    <block wx:if="{{ item.images.length === 1 }}">
                      <view
                        class="daily-post__img-wrap daily-post__img-wrap--{{ item.imageLayout || 'normal' }}"
                        data-post-id="{{item.id}}"
                        data-img-index="{{0}}"
                        catch:tap="onDailyImageTap"
                      >
                        <image class="daily-post__img" src="{{ item.images[0] }}" mode="aspectFill" />
                      </view>
                    </block>
                    <block wx:else>
                      <view
                        class="daily-post__img-grid daily-post__img-grid--{{ item.images.length === 2 ? 'dual' : 'multi' }}"
                      >
                        <view
                          wx:for="{{ item.images }}"
                          wx:for-item="imgUrl"
                          wx:for-index="imgIdx"
                          wx:key="imgIdx"
                          class="daily-post__img-cell"
                          data-post-id="{{item.id}}"
                          data-img-index="{{imgIdx}}"
                          catch:tap="onDailyImageTap"
                        >
                          <image class="daily-post__img" src="{{ imgUrl }}" mode="aspectFill" />
                        </view>
                      </view>
                    </block>
                  </view>
                </view>
              </view>
            </view>
          </view>
          <view wx:if="{{dailyLoadingMore}}" class="chronicle-load-more">
            <text class="chronicle-load-more-text">加载中…</text>
          </view>
          <view wx:if="{{!dailyHasMore && dailyList.length > 0}}" class="chronicle-load-more chronicle-load-more--muted">
            <text class="chronicle-load-more-text">没有更多了</text>
          </view>
          <view wx:if="{{dailyBootstrapping && dailyList.length === 0}}" class="chronicle-load-more">
            <text class="chronicle-load-more-text">加载中…</text>
          </view>
          <view
            wx:if="{{dailyList.length === 0 && !dailyBootstrapping && !dailyRefreshing}}"
            class="chronicle-empty chronicle-empty--daily"
          >
            <text class="chronicle-empty-title">还没有日常动态</text>
            <text class="chronicle-empty-hint">记录一条此刻的心情或影像</text>
            <view
              class="chronicle-empty-cta"
              bind:tap="onEmptyComposeTap"
              aria-role="button"
            >
              <text class="chronicle-empty-cta-label">写一条</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </swiper-item>

    <swiper-item class="chronicle-swiper-item">
      <scroll-view
        class="chronicle-pane-scroll"
        scroll-y
        type="list"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
        bounces="{{true}}"
        enable-passive="{{true}}"
        cache-extent="320"
      >
        <view class="chronicle-scroll-body">
          <view wx:for="{{reportDisplayList}}" wx:key="id" class="report-card">
            <view class="report-card-head">
              <view class="report-head-main">
                <text class="report-name">{{item.userName}}</text>
                <text class="report-name-suffix"> 的报备</text>
              </view>
              <view class="report-tag">{{item.tag}}</view>
            </view>
            <text class="report-publish">发布 {{item.publishTime}}</text>
            <view class="report-media">
              <text class="feed-media-placeholder">加载中</text>
            </view>
            <view class="report-body-wrap">
              <text class="report-body">{{item.body}}</text>
              <view wx:if="{{item.readByMe}}" class="report-stamp">已阅</view>
            </view>
            <view wx:if="{{item.comments.length}}" class="report-comments">
              <block wx:for="{{item.comments}}" wx:key="index" wx:for-item="c">
                <text class="report-comment-line">{{c.user}}：{{c.text}}</text>
              </block>
            </view>
          </view>
          <view wx:if="{{reportDisplayList.length === 0}}" class="chronicle-empty">
            <text>暂无内容</text>
          </view>
          <view class="chronicle-scroll-pad" />
        </view>
      </scroll-view>
    </swiper-item>
  </swiper>

  <view
    wx:if="{{mainModule === 'daily'}}"
    class="chronicle-fab"
    bind:tap="onFabTap"
    aria-role="button"
    aria-label="写日常"
  >
    <text class="chronicle-fab-icon" aria-hidden="true">✎</text>
  </view>

</view>
