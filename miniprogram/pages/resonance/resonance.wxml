<view class="resonance-page">
  <app-nav title="共鸣" variant="glass" />

  <view class="resonance-header">
    <view class="resonance-header-surface">
      <view class="resonance-header-inner">
        <view class="resonance-toolbar">
          <view class="resonance-toolbar-shell">
            <view class="resonance-report-tabs" aria-label="报备范围">
              <view class="resonance-report-rail">
                <view
                  class="resonance-report-thumb resonance-report-thumb--{{reportFilterIndex}}"
                  aria-hidden="true"
                />
                <view class="resonance-report-tabs-row">
                  <view
                    class="resonance-report-tab {{reportFilterIndex === 0 ? 'resonance-report-tab--active' : ''}}"
                    data-filter="mine"
                    bind:tap="onTabTap"
                    aria-role="tab"
                    aria-selected="{{reportFilterIndex === 0}}"
                  >
                    <text class="resonance-report-tab-label">我的报备</text>
                  </view>
                  <view
                    class="resonance-report-tab {{reportFilterIndex === 1 ? 'resonance-report-tab--active' : ''}}"
                    data-filter="action_needed"
                    bind:tap="onTabTap"
                    aria-role="tab"
                    aria-selected="{{reportFilterIndex === 1}}"
                  >
                    <text class="resonance-report-tab-label">待处理</text>
                  </view>
                  <view
                    class="resonance-report-tab {{reportFilterIndex === 2 ? 'resonance-report-tab--active' : ''}}"
                    data-filter="all"
                    bind:tap="onTabTap"
                    aria-role="tab"
                    aria-selected="{{reportFilterIndex === 2}}"
                  >
                    <text class="resonance-report-tab-label">全部</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <swiper
    class="resonance-swiper"
    current="{{reportFilterIndex}}"
    duration="{{300}}"
    cache-extent="1"
    bindchange="onSwiperChange"
  >
    <swiper-item wx:for="{{tabs}}" wx:key="filter">
      <scroll-view
        class="resonance-pane-scroll"
        scroll-y
        type="list"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
        bounces="{{true}}"
        enable-passive="{{true}}"
        cache-extent="320"
        refresher-enabled="{{true}}"
        refresher-triggered="{{item.refreshing}}"
        bindrefresherrefresh="onReportRefresh"
        bindscrolltolower="onReportScrollToLower"
        lower-threshold="{{120}}"
        data-tab="{{index}}"
      >
        <view class="resonance-scroll-body">

          <!-- 静默刷新指示器 -->
          <view class="resonance-silent-refresh" aria-hidden="true">
            <view wx:if="{{item.silentRefreshing}}" class="resonance-silent-refresh-bar" />
          </view>

          <block wx:for="{{item.groups}}" wx:key="dateKey">
            <view class="resonance-date-head">
              <view class="resonance-date-head__line" />
              <text class="resonance-date-head__label">{{item.dateLabel}}</text>
              <view class="resonance-date-head__line" />
            </view>
            <view
              wx:for="{{item.posts}}"
              wx:for-item="post"
              wx:key="id"
              list-item
              class="report-card-slot"
              data-id="{{post.id}}"
              bind:tap="onReportCardTap"
              bind:longpress="onReportPostLongPress"
            >
              <view class="report-card report-card--{{post.partnerState}}">

                <!-- 头部 -->
                <view class="report-card-head">
                  <view class="report-card-head-row">
                    <view class="report-card-status-dot"></view>
                    <text class="report-card-name">{{post.userName}}</text>
                    <text class="report-card-suffix"> 的报备</text>
                    <view wx:if="{{post.tagChips && post.tagChips.length}}" class="report-card-head-tags">
                      <view
                        wx:for="{{post.tagChips}}"
                        wx:for-item="chip"
                        wx:key="name"
                        class="report-tag-chip report-tag-chip--c{{chip.colorIdx}}"
                      >
                        <text class="report-tag-chip-text">{{chip.name}}</text>
                      </view>
                    </view>
                  </view>
                  <view class="report-card-head-sub">
                    <text class="report-card-record-label">记录于</text>
                    <text class="report-card-record-time">{{post.recordTimeStr}}</text>
                  </view>
                </view>

                <!-- 内容 -->
                <view class="report-card-body-zone">

                <!-- 正文 + 配图 -->
                <view
                  wx:if="{{post.body || (post.images && post.images.length)}}"
                  class="report-card-main"
                >
                  <view wx:if="{{post.body}}" class="report-card-body">
                    <text class="report-card-body-text">{{post.body}}</text>
                  </view>
                  <view
                    wx:if="{{post.images && post.images.length}}"
                    class="report-card-media {{ post.images.length === 1 ? 'report-card-media--one' : post.images.length === 2 ? 'report-card-media--two' : 'report-card-media--many' }}"
                  >
                    <view wx:for="{{post.images}}" wx:for-item="img" wx:for-index="ix" wx:key="ix" class="report-card-media-cell">
                      <image class="report-card-media-thumb" src="{{img}}" mode="aspectFill" data-post-id="{{post.id}}" data-img-index="{{ix}}" catch:tap="onReportImageTap" />
                    </view>
                  </view>
                </view>

                <!-- 对方评价 -->
                <view wx:if="{{post.partnerEvalText}}" class="report-card-eval">
                  <text class="report-card-eval-label">对方的评价</text>
                  <text class="report-card-eval-text">{{post.partnerEvalText}}</text>
                </view>

                </view><!-- /report-card-body-zone -->

              </view>
            </view>
          </block>

          <view wx:if="{{item.bootstrapping && item.list.length === 0}}" class="resonance-load-more">
            <text class="resonance-load-more-text">加载中…</text>
          </view>
          <view wx:if="{{item.list.length === 0 && !item.bootstrapping && !item.refreshing && item.everLoaded}}" class="resonance-empty">
            <text class="resonance-empty-title">还没有报备</text>
            <text class="resonance-empty-hint">记录一件想告诉对方的小事，点右下角按钮即可开始</text>
          </view>

          <view class="resonance-scroll-pad" />
        </view>
      </scroll-view>
    </swiper-item>
  </swiper>

  <view class="resonance-compose-fab resonance-compose-fab--fixed" bind:tap="onReportComposeFabTap" bind:longpress="onReportComposeFabLongPress" aria-role="button" aria-label="写报备">
    <template is="resonance-compose-plus" />
  </view>

  <template name="resonance-compose-plus">
    <view class="resonance-compose-fab__plus" aria-hidden="true">
      <view class="resonance-compose-fab__bar resonance-compose-fab__bar--h" />
      <view class="resonance-compose-fab__bar resonance-compose-fab__bar--v" />
    </view>
  </template>
</view>
