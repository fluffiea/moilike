/* 独白页：米杏 / 鼠尾草绿；布局类配合 Tailwind（无 [] 任意值，避免 WXML 与转义 WXSS 不一致） */

page {
  height: 100vh;
  background-color: #f7f4f0;
}

.profile-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background-color: #f7f4f0;
}

.page-scroll {
  flex: 1;
  min-height: 0;
  padding-bottom: 48rpx;
}

.hero {
  padding: 56rpx 40rpx 48rpx;
  background: linear-gradient(180deg, #ebe3d7 0%, #d6c9b5 45%, #ddd4c8 100%);
}

.hero-decor {
  position: absolute;
  top: 36rpx;
  right: 40rpx;
  gap: 20rpx;
  opacity: 0.45;
}

.hero-decor-flower,
.hero-decor-cross {
  font-size: 28rpx;
  color: #6d8a78;
}

.avatar-ring {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
  padding: 8rpx;
  border-radius: 50%;
  border: 6rpx solid #8da399;
  background-color: #ffffff;
}

.avatar-img {
  border-radius: 50%;
}

.hero-nick {
  margin-top: 32rpx;
  font-size: 40rpx;
  color: #5a7360;
}

.hero-handle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8da399;
}

.hero-sign {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(40, 38, 36, 0.55);
  padding: 0 32rpx;
}

.settings-card {
  margin: 24rpx 28rpx 32rpx;
  padding: 8rpx 0;
  border-radius: 24rpx;
  background-color: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(90, 80, 70, 0.08);
}

.settings-row {
  min-height: 96rpx;
  padding: 0 32rpx;
}

.settings-row-line {
  border-bottom: 1rpx solid rgba(141, 163, 153, 0.22);
}

.settings-icon {
  width: 48rpx;
  margin-right: 20rpx;
  font-size: 34rpx;
}

.settings-label {
  font-size: 30rpx;
  color: rgba(40, 38, 36, 0.88);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settings-chevron {
  font-size: 32rpx;
  color: rgba(141, 163, 153, 0.65);
}

.logout-btn {
  margin: 0 40rpx 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  color: #c97b8f;
  background-color: #f5e6e6;
  border: 2rpx solid #e8c4ce;
}

.footer-tag {
  font-size: 22rpx;
  color: rgba(141, 163, 153, 0.85);
  letter-spacing: 2rpx;
  padding: 0 32rpx;
}
