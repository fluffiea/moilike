<!--
  [Layering] L0 #F2F2F7 + 极淡顶区浸润 · L1 身份卡/设置/对象摘要入口/退出 §2.3 · 顶栏 L2 app-nav glass
  [Spacing] 水平 40rpx；卡间距 32–36rpx；8rpx 阶梯
  [Palette 6-3-1] 正文 #1C1C1E / #8E8E93；品牌渐变仅主按钮、行内 CTA
-->
<view class="profile-shell">
  <app-nav title="独白" variant="glass" />
  <scroll-view
    class="profile-scroll"
    scroll-y
    type="list"
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="profile-scroll-body">
      <view class="profile-identity-card">
        <view class="profile-identity-card__wash" aria-hidden="true" />
        <view class="profile-hero">
          <view class="profile-avatar-stack">
            <view class="profile-avatar-glow" aria-hidden="true" />
            <view class="profile-avatar-ring">
              <view class="profile-avatar-inner">
                <image
                  class="profile-avatar-img"
                  src="{{avatarUrl}}"
                  mode="aspectFill"
                  binderror="onMyAvatarError"
                />
              </view>
            </view>
          </view>
          <view class="profile-identity-text">
            <text class="profile-nick">{{nickName}}</text>
            <view class="profile-sign-wrap">
              <text class="profile-sign">{{signature}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="profile-settings-card">
        <view class="profile-settings-heading" aria-hidden="true">账户与偏好</view>
        <view
          wx:for="{{settingsRows}}"
          wx:key="id"
          class="profile-settings-row {{index < settingsRows.length - 1 ? 'profile-settings-row--line' : ''}}"
          data-id="{{item.id}}"
          bind:tap="onSettingTap"
          aria-role="button"
          aria-label="{{item.id == 'editProfile' || item.id == 'preferences' ? item.label : item.label + '，敬请期待'}}"
        >
          <view class="profile-settings-icon-wrap" aria-hidden="true">
            <text class="profile-settings-icon">{{item.icon}}</text>
          </view>
          <text class="profile-settings-label">{{item.label}}</text>
          <text class="profile-settings-chevron" aria-hidden="true">›</text>
        </view>
      </view>

      <view
        class="profile-couple-peek"
        bind:tap="onCoupleHubTap"
        aria-role="button"
        aria-label="查看恋爱关系与绑定详情"
      >
        <view wx:if="{{partner && partner.openId}}" class="profile-couple-peek-inner">
          <view class="profile-couple-peek-avatar-ring" aria-hidden="true">
            <image
              class="profile-couple-peek-avatar"
              src="{{partner.avatarUrl || defaultAvatar}}"
              mode="aspectFill"
              binderror="onPartnerPeekAvatarError"
            />
          </view>
          <view class="profile-couple-peek-text">
            <text class="profile-couple-peek-title">与「{{partner.nickName || 'Ta'}}」已结伴</text>
            <text class="profile-couple-peek-sub">绑定码与申请进度 · 轻点查看</text>
          </view>
          <text class="profile-couple-peek-chevron" aria-hidden="true">›</text>
        </view>
        <view wx:else class="profile-couple-peek-inner">
          <view class="profile-couple-peek-placeholder" aria-hidden="true" />
          <view class="profile-couple-peek-text">
            <text class="profile-couple-peek-title">还没有结伴对象</text>
            <text class="profile-couple-peek-sub">分享绑定码，或处理对方发来的申请</text>
          </view>
          <text class="profile-couple-peek-chevron" aria-hidden="true">›</text>
        </view>
      </view>

      <view
        class="profile-logout"
        bind:tap="onLogoutTap"
        aria-role="button"
        aria-label="退出登录"
      >
        退出登录
      </view>

      <text class="profile-footer">{{tagLine}}</text>
    </view>
  </scroll-view>
</view>
