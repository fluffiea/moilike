<scroll-view class="page-scroll flex h-full min-h-0 flex-col box-border" scroll-y type="list">
  <view class="hero relative">
    <view class="hero-decor flex flex-row items-center" aria-hidden="true">
      <text class="hero-decor-flower">✿</text>
      <text class="hero-decor-cross">╋</text>
    </view>
    <view class="avatar-ring">
      <image class="avatar-img block h-full w-full" src="{{avatarUrl}}" mode="aspectFill" />
    </view>
    <text class="hero-nick block text-center font-bold">{{nickName}}</text>
    <text class="hero-handle block text-center font-medium">{{handle}}</text>
    <text class="hero-sign block text-center font-normal">{{signature}}</text>
  </view>

  <view class="settings-card">
    <view
      wx:for="{{settingsRows}}"
      wx:key="id"
      class="settings-row flex flex-row items-center {{index < settingsRows.length - 1 ? 'settings-row-line' : ''}}"
      data-id="{{item.id}}"
      bind:tap="onSettingTap"
      aria-role="button"
      aria-label="{{item.label}}，敬请期待"
    >
      <text class="settings-icon shrink-0 text-center" aria-hidden="true">{{item.icon}}</text>
      <text class="settings-label min-w-0 flex-1 font-medium">{{item.label}}</text>
      <text class="settings-chevron shrink-0 font-normal" aria-hidden="true">›</text>
    </view>
  </view>

  <view
    class="logout-btn box-border text-center font-semibold"
    bind:tap="onLogoutTap"
    aria-role="button"
    aria-label="退出登录"
  >
    退出登录
  </view>

  <text class="footer-tag block text-center font-medium">{{tagLine}}</text>
</scroll-view>
