<view class="profile-shell">
  <app-nav title="独白" variant="glass" />
  <scroll-view
    class="profile-scroll"
    scroll-y
    type="list"
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- type="list"：单容器包裹，避免多子项布局裁切 padding -->
    <view class="profile-scroll-body">
      <view class="profile-identity-card">
        <view class="profile-decor" aria-hidden="true">
          <text class="profile-decor-dot">✿</text>
          <text class="profile-decor-cross">╋</text>
        </view>
        <view class="profile-avatar-ring">
          <view class="profile-avatar-inner">
            <image class="profile-avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
          </view>
        </view>
        <text class="profile-nick">{{nickName}}</text>
        <text class="profile-sign">{{signature}}</text>
      </view>

      <view class="profile-settings-card">
        <view
          wx:for="{{settingsRows}}"
          wx:key="id"
          class="profile-settings-row {{index < settingsRows.length - 1 ? 'profile-settings-row--line' : ''}}"
          data-id="{{item.id}}"
          bind:tap="onSettingTap"
          hover-class="profile-settings-row-hover"
          hover-stay-time="70"
          aria-role="button"
          aria-label="{{item.label}}，敬请期待"
        >
          <text class="profile-settings-icon" aria-hidden="true">{{item.icon}}</text>
          <text class="profile-settings-label">{{item.label}}</text>
          <text class="profile-settings-chevron" aria-hidden="true">›</text>
        </view>
      </view>

      <view
        class="profile-logout"
        bind:tap="onLogoutTap"
        hover-class="profile-logout-hover"
        hover-stay-time="70"
        aria-role="button"
        aria-label="退出登录"
      >
        退出登录
      </view>

      <text class="profile-footer">{{tagLine}}</text>
    </view>
  </scroll-view>
</view>
