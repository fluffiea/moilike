<view class="moments-page">
  <app-nav title="浮生" variant="glass" />

  <scroll-view
    class="moments-scroll"
    scroll-y
    type="list"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    bounces="{{true}}"
    enable-passive="{{true}}"
    cache-extent="320"
    refresher-enabled="{{true}}"
    refresher-triggered="{{dailyRefreshing}}"
    bindrefresherrefresh="onDailyRefresh"
    bindscrolltolower="onDailyScrollToLower"
    bindscroll="onDailyScroll"
    scroll-top="{{dailyScrollToTop}}"
    scroll-with-animation="{{true}}"
    lower-threshold="{{120}}"
  >
    <view class="moments-feed">
      <view class="daily-filter-bar">
        <picker class="daily-filter-bar__picker" mode="date" value="{{dailyFilterDateKey}}" bindchange="onDailyFilterDateChange">
          <view class="daily-filter-bar__label">
            <text>{{dailyFilterDateKey || '全部'}}</text>
            <text class="daily-filter-bar__arrow">▾</text>
          </view>
        </picker>
        <view wx:if="{{dailyFilterDateKey}}" class="daily-filter-bar__clear" bind:tap="onDailyFilterClear">
          <text>✕</text>
        </view>
      </view>

      <block wx:for="{{dailyFilteredGroups}}" wx:key="dateKey">
        <view class="daily-date-head">
          <view class="daily-date-head__line" />
          <text class="daily-date-head__label">{{item.dateLabel}}</text>
          <view class="daily-date-head__line" />
        </view>
        <view
          wx:for="{{item.posts}}"
          wx:for-item="post"
          wx:key="id"
          list-item
          class="daily-post"
          data-id="{{post.id}}"
          bind:tap="onDailyPostTap"
          bind:longpress="onDailyPostLongPress"
        >
          <view class="daily-post__body">
            <view class="daily-post__main">
              <view class="daily-post__head">
                <view class="daily-post__avatar-shell {{post.isMine ? 'daily-post__avatar-shell--mine' : 'daily-post__avatar-shell--partner'}}">
                  <image
                    wx:if="{{ post.avatarUrl }}"
                    class="daily-post__avatar daily-post__avatar--photo"
                    src="{{ post.avatarUrl }}"
                    mode="aspectFill"
                  />
                  <view
                    wx:else
                    class="daily-post__avatar-ph daily-post__ph--{{ post.avatarTone || 'dew' }}"
                    aria-hidden="true"
                  >
                    <view class="daily-post__ph-shine" />
                  </view>
                </view>
                <view class="daily-post__head-main">
                  <view class="daily-post__head-row">
                    <view class="daily-post__name">{{post.userName}}</view>
                    <text class="daily-post__time">{{post.time}}</text>
                  </view>
                </view>
              </view>
              <view
                wx:if="{{ post.snippet || post.images.length }}"
                class="daily-post__content"
              >
                <view wx:if="{{post.snippet}}" class="daily-post__prose">
                  <text class="daily-post__text">{{post.snippet}}</text>
                </view>
                <view wx:if="{{ post.images.length }}" class="daily-post__media">
                  <block wx:if="{{ post.images.length === 1 }}">
                    <view
                      class="daily-post__img-wrap daily-post__img-wrap--{{ post.imageLayout || 'normal' }}"
                      data-post-id="{{post.id}}"
                      data-img-index="{{0}}"
                      catch:tap="onDailyImageTap"
                    >
                      <image class="daily-post__img" src="{{ post.images[0] }}" mode="aspectFill" />
                    </view>
                  </block>
                  <block wx:else>
                    <view
                      class="daily-post__img-grid daily-post__img-grid--{{ post.images.length === 2 ? 'dual' : 'multi' }}"
                    >
                      <view
                        wx:for="{{ post.images }}"
                        wx:for-item="imgUrl"
                        wx:for-index="imgIdx"
                        wx:key="imgIdx"
                        class="daily-post__img-cell"
                        data-post-id="{{post.id}}"
                        data-img-index="{{imgIdx}}"
                        catch:tap="onDailyImageTap"
                      >
                        <image class="daily-post__img" src="{{ imgUrl }}" mode="aspectFill" />
                      </view>
                    </view>
                  </block>
                </view>
              </view>
            </view>
          </view>
          <view wx:if="{{ post.commentCount > 0 }}" class="daily-post__preview">
            <view class="daily-post__preview-inner" aria-hidden="true">
              <text class="daily-post__preview-author">{{post.firstCommentUserName}}</text>
              <text class="daily-post__preview-colon">：</text>
              <text class="daily-post__preview-snippet" overflow="ellipsis" max-lines="2">{{post.firstCommentText}}</text>
            </view>
            <text class="daily-post__preview-count">{{post.commentCountLabel}}</text>
          </view>
        </view>
      </block>
      <view wx:if="{{dailyLoadingMore}}" class="moments-load-more">
        <text class="moments-load-more-text">加载中…</text>
      </view>
      <view wx:if="{{!dailyHasMore && dailyList.length > 0}}" class="moments-load-more moments-load-more--muted">
        <text class="moments-load-more-text">没有更多了</text>
      </view>
      <view wx:if="{{dailyBootstrapping && dailyList.length === 0}}" class="moments-load-more">
        <text class="moments-load-more-text">加载中…</text>
      </view>
      <view
        wx:if="{{dailyList.length === 0 && !dailyBootstrapping && !dailyRefreshing}}"
        class="moments-empty moments-empty--daily"
      >
        <text class="moments-empty-title">还没有日常动态</text>
        <text class="moments-empty-hint">记录一条此刻的心情或影像，点右下角按钮即可开始</text>
      </view>
    </view>
  </scroll-view>

  <view class="moments-compose-fab moments-compose-fab--fixed" bind:tap="onComposeFabTap" bind:longpress="onComposeFabLongPress" aria-role="button" aria-label="写日常">
    <template is="moments-compose-plus" />
  </view>

  <view wx:if="{{dailyShowBackTop}}" class="daily-back-top" bind:tap="onDailyBackTop" aria-role="button" aria-label="回到顶部">
    <view class="daily-back-top__arrow" />
  </view>

  <template name="moments-compose-plus">
    <view class="moments-compose-fab__plus" aria-hidden="true">
      <view class="moments-compose-fab__bar moments-compose-fab__bar--h" />
      <view class="moments-compose-fab__bar moments-compose-fab__bar--v" />
    </view>
  </template>
</view>
