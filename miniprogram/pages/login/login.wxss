/* 登录页：与独白 / 见证统一的暖杏 + 鼠尾草，卡片式表单 */

page {
  height: 100vh;
  background-color: #f4f0ea;
}

.login-page {
  min-height: 100vh;
}

.login-checking {
  box-sizing: border-box;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  gap: 28rpx;
}

.login-checking-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(102, 143, 128, 0.25);
  border-top-color: #668f80;
  animation: login-spin 0.85s linear infinite;
}

@keyframes login-spin {
  to {
    transform: rotate(360deg);
  }
}

.login-checking-text {
  font-size: 28rpx;
  color: rgba(74, 95, 82, 0.85);
}

.login-scroll {
  box-sizing: border-box;
  width: 100%;
  height: 100vh;
  padding: 0 0 calc(48rpx + env(safe-area-inset-bottom));
}

/* 与 scroll-view 解耦：真正的内容区，保证卡片内边距等样式不被 type="list" 多子项布局影响 */
.login-scroll-body {
  box-sizing: border-box;
  width: 100%;
  min-height: 100%;
}

.login-hero {
  position: relative;
  padding: 48rpx 100rpx 36rpx 40rpx;
  background: linear-gradient(180deg, #ebe3d7 0%, #dfd4c8 70%, #f0ebe6 100%);
  overflow: hidden;
}

.login-hero-decor {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  font-size: 26rpx;
  color: #668f80;
  opacity: 0.45;
}

.login-hero-decor-dot {
  font-size: 22rpx;
}

.login-brand {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: #5a7d6e;
  margin-bottom: 12rpx;
}

.login-tagline {
  display: block;
  font-size: 24rpx;
  color: rgba(74, 68, 62, 0.72);
  margin-bottom: 28rpx;
}

.login-hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #4a5f52;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.login-hero-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.65;
  color: rgba(61, 56, 53, 0.62);
  max-width: 620rpx;
  margin-bottom: 0;
}

.login-card {
  margin: -28rpx 28rpx 0;
  padding: 56rpx 40rpx 48rpx;
  border-radius: 28rpx;
  background-color: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.login-section {
  margin-bottom: 0;
}

.login-section-head {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

/* 头像区：标题与说明纵向排列，避免一行两端留白很「散」 */
.login-section-head--stack {
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  margin-bottom: 20rpx;
}

.login-section-head--stack .login-section-hint {
  flex: none;
  margin-left: 0;
  margin-top: 8rpx;
  text-align: left;
  line-height: 1.45;
  max-width: 100%;
}

.login-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #4a5f52;
}

/* 昵称等：标题与输入框之间的固定间距 */
.login-section > .login-section-title {
  display: block;
  margin-bottom: 12rpx;
}

.login-section-hint {
  font-size: 22rpx;
  color: #8da399;
  flex: 1;
  margin-left: 16rpx;
  text-align: right;
}

.login-char-count {
  font-size: 22rpx;
  color: #a3988c;
}

.login-avatar-row {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 0 0 4rpx;
}

/* 图片在 view 内铺满正方形，aspectFill 裁切不变形；透明 button 仅负责点击，避免原生 button 挤压子级导致拉伸 */
.login-avatar-btn-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  box-sizing: border-box;
  border: 6rpx solid #8da399;
  background-color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(102, 143, 128, 0.15);
}

.login-avatar-img {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.login-avatar-hit {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 2;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  min-width: 0;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0);
  line-height: 0;
  font-size: 0;
}

.login-avatar-hit::after {
  border: none;
}

.login-divider {
  height: 1rpx;
  margin: 20rpx 0 24rpx;
  background: linear-gradient(
    90deg,
    rgba(102, 143, 128, 0) 0%,
    rgba(102, 143, 128, 0.18) 50%,
    rgba(102, 143, 128, 0) 100%
  );
}

.login-field-shell {
  box-sizing: border-box;
  padding: 0;
  border-radius: 0;
  background-color: transparent;
  border: none;
}

.login-field-shell-area {
  padding: 0;
}

.login-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 96rpx;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  line-height: 1.45;
  color: #2c2c2c;
  background-color: #f9f8f6;
  border-radius: 20rpx;
  border: 2rpx solid rgba(102, 143, 128, 0.18);
}

.login-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 140rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #2c2c2c;
  background-color: #ffffff;
  border-radius: 12rpx;
}

.login-placeholder {
  color: rgba(90, 82, 74, 0.42);
}

.login-submit-wrap {
  box-sizing: border-box;
  width: 100%;
  padding: 40rpx 48rpx 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.login-submit {
  width: 86%;
  max-width: 420rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7a9d8e 0%, #5d8274 100%);
  color: #fffef9;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  box-shadow: 0 8rpx 22rpx rgba(102, 143, 128, 0.28);
}

.login-submit::after {
  border: none;
}

.login-submit[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.login-footnote {
  display: block;
  box-sizing: border-box;
  margin: 28rpx 0 0;
  padding: 0 56rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.55;
  color: rgba(90, 82, 74, 0.48);
}
