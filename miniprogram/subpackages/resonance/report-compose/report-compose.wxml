<!--
  报备编辑页 · moilike-ui · Skyline — 多卡表单
  [Layering] L0 灰底 + L1 独立卡片（§2.3 阴影）+ L2 玻璃顶栏/底栏
  [Spacing] 40rpx 水平起点，卡片间 24rpx gap，核心输入区 36rpx 卡内边距，非输入区 compact
  [Order] 正文 → 配图（核心区）→ 记录时间 → 标签（非输入区，紧凑置底）
-->
<view class="report-compose-page">
  <view class="report-compose-bg" aria-hidden="true">
    <view class="report-compose-bg-wash" />
  </view>

  <view class="report-compose-stack">
    <app-nav title="{{navTitle}}" variant="glass" show-back="{{true}}" bind:back="onNavBack" />

    <scroll-view class="report-compose-scroll" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" bounces="{{true}}">
      <view class="report-compose-scroll-inner">

        <!-- 页级引导语 -->
        <text class="report-compose-kicker">{{heroKicker}}</text>

        <!-- Card 1: 正文 -->
        <view class="report-compose-card">
          <view class="report-compose-card-head">
            <text class="report-compose-card-label">正文</text>
            <text class="report-compose-card-meta">{{text.length}} / 2000</text>
          </view>
          <view class="report-compose-field-shell">
            <textarea
              id="{{textareaMountKey}}"
              class="report-compose-textarea"
              placeholder="写报备内容…"
              placeholder-class="report-compose-placeholder"
              maxlength="{{2000}}"
              model:value="{{text}}"
              bindinput="onTextInput"
              auto-height
              show-confirm-bar="{{false}}"
              cursor-spacing="{{24}}"
            />
          </view>
        </view>

        <!-- Card 2: 配图 -->
        <view class="report-compose-card">
          <view class="report-compose-card-head">
            <text class="report-compose-card-label">配图</text>
            <view class="report-compose-chip">
              <text class="report-compose-chip-text">{{images.length}} / 9</text>
            </view>
          </view>
          <view class="report-compose-grid" aria-label="配图网格">
            <view wx:for="{{images}}" wx:for-index="imgIdx" wx:key="imgIdx" class="report-compose-cell report-compose-cell--pic">
              <image class="report-compose-thumb" src="{{imageDisplays[imgIdx]}}" mode="aspectFill" />
              <view class="report-compose-remove" data-index="{{imgIdx}}" catch:tap="onRemoveImage" aria-role="button" aria-label="删除此图">
                <view class="report-compose-remove-x">×</view>
              </view>
            </view>

            <view wx:if="{{images.length < 9}}" class="report-compose-cell report-compose-cell--add">
              <view class="report-compose-add-fill" bind:tap="onAddImagesFromAlbum" bind:longpress="onAddImagesFromCamera" aria-role="button" aria-label="添加图片，轻点相册或长按拍摄">
                <text class="report-compose-add-plus">+</text>
                <text class="report-compose-add-line">添加</text>
                <text class="report-compose-add-sub">还可 {{9 - images.length}} 张</text>
              </view>
            </view>
          </view>
        </view>

        <!-- Card 3: 记录时间 -->
        <view class="report-compose-card report-compose-card--compact">
          <view class="report-compose-card-head">
            <text class="report-compose-card-label report-compose-card-label--sm">记录时间</text>
            <view class="report-compose-time-badge {{recordTimeModified ? 'report-compose-time-badge--custom' : 'report-compose-time-badge--now'}}">
              <text class="report-compose-time-badge-dot" aria-hidden="true">●</text>
              <text class="report-compose-time-badge-text">{{recordTimeModified ? '已自定义' : '当前时刻'}}</text>
            </view>
          </view>
          <view class="report-compose-pickers report-compose-pickers--row">
            <view class="report-compose-picker-col report-compose-picker-col--half">
              <picker mode="date" value="{{recordDateStr}}" bindchange="onRecordDateChange">
                <view class="report-compose-picker-val report-compose-picker-val--sm" aria-role="button">
                  <text>{{recordDateStr}}</text>
                  <text class="report-compose-picker-chevron" aria-hidden="true">›</text>
                </view>
              </picker>
            </view>
            <view class="report-compose-picker-col report-compose-picker-col--half">
              <picker mode="time" value="{{recordTimeStr}}" bindchange="onRecordTimeChange">
                <view class="report-compose-picker-val report-compose-picker-val--sm" aria-role="button">
                  <text>{{recordTimeStr}}</text>
                  <text class="report-compose-picker-chevron" aria-hidden="true">›</text>
                </view>
              </picker>
            </view>
          </view>
        </view>

        <!-- Card 4: 标签 -->
        <view class="report-compose-card report-compose-card--compact">
          <view class="report-compose-card-head">
            <text class="report-compose-card-label report-compose-card-label--sm">标签</text>
            <text class="report-compose-card-meta">可多选</text>
          </view>
          <view class="report-compose-tag-wrap">
            <view
              wx:for="{{tagRows}}"
              wx:key="name"
              class="report-compose-tag-chip {{item.selected ? 'report-compose-tag-chip--on' : ''}}"
              data-tag="{{item.name}}"
              bind:tap="onToggleTag"
              aria-role="button"
              aria-pressed="{{item.selected}}"
            >
              <text class="report-compose-tag-chip-text">{{item.name}}</text>
            </view>
            <input
              class="report-compose-tag-input"
              value="{{newTagDraft}}"
              bindinput="onNewTagInput"
              bindconfirm="onAddCustomTag"
              placeholder="+ 新标签"
              placeholder-class="report-compose-tag-input-placeholder"
              maxlength="{{16}}"
              confirm-type="done"
              adjust-position="{{false}}"
            />
          </view>
        </view>

        <view class="report-compose-scroll-pad" />
      </view>
    </scroll-view>

    <view class="report-compose-footer">
      <view wx:if="{{!canSubmit}}" class="report-compose-footer-hint">
        <text class="report-compose-footer-hint-text">填写文字或添加图片后即可提交</text>
      </view>
      <view class="report-compose-footer-inner">
        <view class="report-compose-publish {{canSubmit ? '' : 'report-compose-publish--disabled'}}" bind:tap="onSubmit" aria-role="button" aria-label="{{editId ? '保存修改' : '发布报备'}}">
          <text class="report-compose-publish-label">{{editId ? '保存修改' : '发布报备'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
