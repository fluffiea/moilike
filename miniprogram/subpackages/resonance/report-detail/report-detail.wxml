<!--
  报备详情页 · moilike-ui · Skyline
  [Layering] L0 灰底 + L1 白卡 左柔光（对齐共鸣卡）
  [Structure] 完全对齐列表卡：圆点+名称+标签同行 → 记录于 → 正文+配图+评价
-->
<view class="report-detail-page">
  <view class="report-detail-bg" aria-hidden="true">
    <view class="report-detail-bg-wash" />
  </view>
  <view class="report-detail-stack">
    <app-nav
      title="报备详情"
      variant="glass"
      show-back="{{true}}"
      bind:back="onNavBack"
    />
    <scroll-view
      wx:if="{{post}}"
      class="report-detail-scroll"
      scroll-y
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
      bounces="{{true}}"
    >
      <view class="report-detail-inner">
        <view class="report-detail-card report-detail-card--{{post.partnerState}}">

          <!-- 头部（对齐 report-card-head） -->
          <view class="report-detail-card-head">
            <view class="report-detail-card-head-row">
              <view class="report-detail-card-status-dot"></view>
              <text class="report-detail-card-name">{{post.userName}}</text>
              <text class="report-detail-card-suffix"> 的报备</text>
              <view
                wx:if="{{post.tagChips && post.tagChips.length}}"
                class="report-detail-card-head-tags"
              >
                <view
                  wx:for="{{post.tagChips}}"
                  wx:for-item="chip"
                  wx:key="name"
                  class="report-tag-chip report-tag-chip--c{{chip.colorIdx}}"
                >
                  <text class="report-tag-chip-text">{{chip.name}}</text>
                </view>
              </view>
              <view
                wx:if="{{post.isMine}}"
                class="report-detail-card-more"
                bind:tap="onMoreActions"
                aria-role="button"
                aria-label="更多操作"
              >
                <text class="report-detail-card-more-icon">⋯</text>
              </view>
            </view>
            <view class="report-detail-card-head-sub">
              <text class="report-detail-card-record-label">记录于</text>
              <text class="report-detail-card-record-time">{{post.recordTimeStr}}</text>
            </view>
          </view>

          <!-- 内容区（对齐 report-card-body-zone） -->
          <view class="report-detail-card-body-zone">

            <view
              wx:if="{{post.body || (post.images && post.images.length)}}"
              class="report-detail-card-main"
            >
              <view wx:if="{{post.body}}" class="report-detail-card-body">
                <text class="report-detail-card-body-text">{{post.body}}</text>
              </view>
              <view
                wx:if="{{post.images && post.images.length}}"
                class="report-detail-card-media {{imageLayoutClass}}"
              >
                <view
                  wx:for="{{post.images}}"
                  wx:for-item="img"
                  wx:for-index="ix"
                  wx:key="ix"
                  class="report-detail-card-media-cell"
                >
                  <image
                    class="report-detail-card-media-thumb"
                    src="{{img}}"
                    mode="aspectFill"
                    data-index="{{ix}}"
                    bind:tap="onImageTap"
                  />
                </view>
              </view>
            </view>

            <!-- 对方评价 -->
            <view
              wx:if="{{post.partnerEvalText && !evalEditing && !post.canEvaluate}}"
              class="report-detail-card-eval"
            >
              <view class="report-detail-card-eval-top">
                <text class="report-detail-card-eval-label">对方的评价</text>
                <view
                  wx:if="{{post.canEditEval}}"
                  class="report-detail-card-eval-edit"
                  bind:tap="onStartEditEval"
                  aria-role="button"
                  aria-label="编辑评价"
                >
                  <text class="report-detail-card-eval-edit-text">编辑</text>
                </view>
              </view>
              <text class="report-detail-card-eval-text">{{post.partnerEvalText}}</text>
            </view>

          </view>

        </view>

        <!-- 评价编辑表单（独立卡片） -->
        <view
          wx:if="{{post.canEvaluate || evalEditing}}"
          class="report-detail-card report-detail-eval-form-card"
        >
          <view class="report-detail-eval-form-top">
            <text class="report-detail-eval-form-lab">{{evalEditing ? '编辑评价' : '写一句评价'}}</text>
            <view
              wx:if="{{evalEditing}}"
              class="report-detail-eval-cancel"
              bind:tap="onCancelEditEval"
              aria-role="button"
            >
              <text class="report-detail-eval-cancel-text">取消</text>
            </view>
          </view>
          <view class="report-detail-eval-shell">
            <textarea
              class="report-detail-eval-area"
              placeholder="对方会先看到你的已阅，再读这里…"
              placeholder-class="report-detail-ph"
              maxlength="{{500}}"
              value="{{evalDraft}}"
              bindinput="onEvalInput"
              auto-height
              show-confirm-bar="{{false}}"
              cursor-spacing="{{24}}"
            />
          </view>
          <view class="report-detail-eval-form-actions">
            <view
              class="report-detail-btn"
              bind:tap="onSubmitEval"
              aria-role="button"
            >
              <text class="report-detail-btn-text">{{evalEditing ? '更新评价' : '提交评价'}}</text>
            </view>
          </view>
        </view>

        <!-- 标记已阅 -->
        <view wx:if="{{post.canMarkRead}}" class="report-detail-actions">
          <view class="report-detail-btn" bind:tap="onMarkRead" aria-role="button">
            <text class="report-detail-btn-text">标记已阅</text>
          </view>
        </view>

        <view class="report-detail-pad" />
      </view>
    </scroll-view>

    <view wx:else class="report-detail-empty">
      <text class="report-detail-empty-text">{{postLoading ? '加载中…' : '无法加载'}}</text>
    </view>
  </view>
</view>
