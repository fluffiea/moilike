<view class="report-detail-page">
  <view class="report-detail-bg" aria-hidden="true">
    <view class="report-detail-bg-wash" />
  </view>
  <view class="report-detail-stack">
    <app-nav
      title="报备详情"
      variant="glass"
      show-back="{{true}}"
      bind:back="onNavBack"
    />
    <scroll-view
      wx:if="{{post}}"
      class="report-detail-scroll"
      scroll-y
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
      bounces="{{true}}"
    >
      <view class="report-detail-inner">
        <view class="report-detail-sheet">

          <!-- 头部 -->
          <view class="report-detail-head">
            <view class="report-detail-avatar-shell">
              <image
                class="report-detail-avatar-img"
                src="{{post.authorAvatarDisplay}}"
                mode="aspectFill"
              />
            </view>
            <view class="report-detail-head-main">
              <view class="report-detail-head-row">
                <text class="report-detail-name">{{post.userName}}</text>
                <text class="report-detail-suffix"> 的报备</text>
              </view>
              <view class="report-detail-head-meta-row">
                <text class="report-detail-publish">发布 {{post.publishTimeStr}}</text>
                <view class="report-detail-status report-detail-status--{{post.partnerState}}">{{post.statusLabel}}</view>
              </view>
            </view>
            <view
              wx:if="{{post.isMine}}"
              class="report-detail-more"
              bind:tap="onMoreActions"
              aria-role="button"
              aria-label="更多操作"
            >
              <text class="report-detail-more-icon">⋯</text>
            </view>
          </view>

          <!-- 标签 -->
          <view class="report-detail-tag-row">
            <view
              wx:for="{{post.tagChips}}"
              wx:for-item="chip"
              wx:key="name"
              class="report-tag-chip report-tag-chip--c{{chip.colorIdx}}"
            >
              <text class="report-tag-chip-text">{{chip.name}}</text>
            </view>
          </view>

          <!-- 记录时间 -->
          <view class="report-detail-record-row">
            <text class="report-detail-record-label">记录时刻</text>
            <text class="report-detail-record-time">{{post.recordTimeStr}}</text>
          </view>

          <!-- 配图 -->
          <view
            wx:if="{{post.images && post.images.length}}"
            class="report-detail-media"
          >
            <view
              wx:for="{{post.images}}"
              wx:for-item="img"
              wx:for-index="ix"
              wx:key="ix"
              class="report-detail-media-cell"
            >
              <image
                class="report-detail-media-thumb"
                src="{{img}}"
                mode="aspectFill"
                data-index="{{ix}}"
                bind:tap="onImageTap"
              />
            </view>
          </view>

          <!-- 正文 -->
          <text class="report-detail-body">{{post.body}}</text>

          <!-- 评价展示区（partnerState='evaluated' 且未在编辑中） -->
          <view
            wx:if="{{post.partnerEvalText && !evalEditing && !post.canEvaluate}}"
            class="report-detail-eval-card {{post.canEditEval ? 'report-detail-eval-card--editable' : ''}}"
          >
            <view class="report-detail-eval-card-top">
              <text class="report-detail-eval-card-label">对方的评价</text>
              <view
                wx:if="{{post.canEditEval}}"
                class="report-detail-eval-edit-hint"
                bind:tap="onStartEditEval"
                aria-role="button"
                aria-label="编辑评价"
              >
                <text class="report-detail-eval-edit-hint-text">编辑</text>
              </view>
            </view>
            <text class="report-detail-eval-card-txt">{{post.partnerEvalText}}</text>
          </view>

          <!-- 标记已阅按钮 -->
          <view wx:if="{{post.canMarkRead}}" class="report-detail-actions">
            <view class="report-detail-btn" bind:tap="onMarkRead" aria-role="button">
              <text class="report-detail-btn-text">标记已阅</text>
            </view>
          </view>

          <!-- 评价编辑表单（首次评价 / 编辑中） -->
          <view wx:if="{{post.canEvaluate || evalEditing}}" class="report-detail-eval-form">
            <view class="report-detail-eval-form-top">
              <text class="report-detail-eval-form-lab">
                {{evalEditing ? '编辑评价' : '写一句评价'}}
              </text>
              <view
                wx:if="{{evalEditing}}"
                class="report-detail-eval-cancel"
                bind:tap="onCancelEditEval"
                aria-role="button"
              >
                <text class="report-detail-eval-cancel-text">取消</text>
              </view>
            </view>
            <view class="report-detail-eval-shell">
              <textarea
                class="report-detail-eval-area"
                placeholder="对方会先看到你的已阅，再读这里…"
                placeholder-class="report-detail-ph"
                maxlength="{{500}}"
                value="{{evalDraft}}"
                bindinput="onEvalInput"
                auto-height
                show-confirm-bar="{{false}}"
                cursor-spacing="{{24}}"
              />
            </view>
            <view
              class="report-detail-btn report-detail-btn--eval"
              bind:tap="onSubmitEval"
              aria-role="button"
            >
              <text class="report-detail-btn-text">{{evalEditing ? '更新评价' : '提交评价'}}</text>
            </view>
          </view>

        </view>
        <view class="report-detail-pad" />
      </view>
    </scroll-view>
    <view wx:else class="report-detail-empty">
      <text class="report-detail-empty-text">{{postLoading ? '加载中…' : '无法加载'}}</text>
    </view>
  </view>
</view>
