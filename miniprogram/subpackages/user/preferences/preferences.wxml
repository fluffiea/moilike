<view class="pref-shell">
  <app-nav
    title="偏好设置"
    variant="glass"
    show-back="{{true}}"
    bind:back="onNavBack"
  />
  <scroll-view
    class="pref-scroll"
    scroll-y
    type="list"
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="pref-scroll-body">
      <view class="pref-card">
        <view class="pref-card__wash" aria-hidden="true" />
        <text class="pref-card-title">共鸣</text>
        <text class="pref-card-desc">打开「共鸣」时报备列表的默认筛选</text>
        <view class="pref-slider" aria-label="共鸣默认筛选">
          <view class="pref-slider-track pref-slider-track--triple">
            <view
              class="pref-slider-thumb pref-slider-thumb--triple pref-slider-thumb--triple-{{reportFilterIndex}}"
              aria-hidden="true"
            />
            <view class="pref-slider-cells pref-slider-cells--triple">
              <view
                class="pref-slider-cell pref-slider-cell--compact {{resonanceReportFilter === 'pending' ? 'pref-slider-cell--on' : ''}}"
                data-filter="pending"
                bind:tap="onPickReportFilter"
                aria-role="tab"
                aria-selected="{{resonanceReportFilter === 'pending'}}"
              >
                <text class="pref-slider-cell-text pref-slider-cell-text--compact">待阅读</text>
              </view>
              <view
                class="pref-slider-cell pref-slider-cell--compact {{resonanceReportFilter === 'all' ? 'pref-slider-cell--on' : ''}}"
                data-filter="all"
                bind:tap="onPickReportFilter"
                aria-role="tab"
                aria-selected="{{resonanceReportFilter === 'all'}}"
              >
                <text class="pref-slider-cell-text pref-slider-cell-text--compact">全部</text>
              </view>
              <view
                class="pref-slider-cell pref-slider-cell--compact {{resonanceReportFilter === 'mine' ? 'pref-slider-cell--on' : ''}}"
                data-filter="mine"
                bind:tap="onPickReportFilter"
                aria-role="tab"
                aria-selected="{{resonanceReportFilter === 'mine'}}"
              >
                <text class="pref-slider-cell-text pref-slider-cell-text--compact">我的</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <text class="pref-footnote">设置将保存在云端，换机登录后仍有效。</text>
    </view>
  </scroll-view>
  <view class="pref-footer">
    <button
      class="pref-save"
      bind:tap="onSave"
      disabled="{{submitting}}"
      loading="{{submitting}}"
      aria-label="保存偏好设置"
    >
      {{submitting ? '保存中…' : '保存'}}
    </button>
  </view>
</view>
