page {
  height: 100vh;
  background-color: #fafafa;
}

.page-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background-color: #fafafa;
}

.page-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.placeholder {
  padding: 48rpx 32rpx;
}

.placeholder-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.placeholder-desc {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.45);
}
