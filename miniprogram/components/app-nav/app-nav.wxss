.app-nav-root {
  flex-shrink: 0;
  width: 100%;
  box-sizing: border-box;
}

.app-nav-safe {
  box-sizing: border-box;
}

.app-nav-bar {
  box-sizing: border-box;
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  border-bottom: 0.5px solid rgba(0, 0, 0, 0.06);
}

.app-nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.88);
  max-width: 70%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
