<view
  class="app-nav-root {{variant === 'glass' ? 'app-nav-root--glass' : ''}}"
  style="{{variant === 'glass' ? '' : 'background-color: ' + bg + ';'}}"
>
  <view class="app-nav-safe" style="padding-top: {{safePaddingTop}}px;">
    <view class="app-nav-bar">
      <view wx:if="{{showBack}}" class="app-nav-leading">
        <view
          class="app-nav-back"
          bind:tap="onBackTap"
          aria-role="button"
          aria-label="返回"
        >
          <text class="app-nav-back-icon" aria-hidden="true">‹</text>
        </view>
      </view>
      <text class="app-nav-title">{{title}}</text>
      <view class="app-nav-trailing" aria-hidden="true" />
    </view>
  </view>
</view>
